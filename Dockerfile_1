# ============================================================
#  Dockerfile — Containerize the trading bot for VPS
# ============================================================

FROM python:3.11-slim

WORKDIR /app

# System dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy source
COPY *.py .

# Create persistent directories (mounted from host)
RUN mkdir -p /app/logs /app/checkpoints /app/data

# Expose dashboard port
EXPOSE 8080

# Run the trainer
CMD ["python", "online_trainer.py"]
